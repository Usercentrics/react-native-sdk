# Resolve react_native_pods.rb with Node to allow hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# ========================================
# NEW ARCHITECTURE CONFIGURATION
# ========================================
# Change this value to control New Architecture:
# true  = Enable New Architecture (TurboModules + Fabric)
# false = Use Legacy Architecture
# ========================================
$RCT_NEW_ARCH_ENABLED = true  # ← CHANGE HERE: true ou false

# React Native environment setup
ENV['RCT_NEW_ARCH_ENABLED'] = $RCT_NEW_ARCH_ENABLED ? '1' : '0'

platform :ios, '15.1'

use_frameworks! :linkage => :static

target 'sample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => $RCT_NEW_ARCH_ENABLED,
    :new_arch_enabled => $RCT_NEW_ARCH_ENABLED,
  )

  # ✅ Test target: inherit search paths only, not full settings
  target 'sampleTests' do
    inherit! :search_paths
  end

  # ✅ Post-install hook (safe for CircleCI and macOS 13+)
  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # ========================================
    # APPLY NEW ARCHITECTURE CONFIGURATION
    # ========================================
    installer.pods_project.targets.each do |target|
      next if target.name.to_s.include?('Tests')

      target.build_configurations.each do |config|
        # Apply New Architecture flags
        if $RCT_NEW_ARCH_ENABLED
          # Enable New Architecture (TurboModules + Fabric)
          config.build_settings['RCT_NEW_ARCH_ENABLED'] = '1'
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-DRCT_NEW_ARCH_ENABLED=1'
          config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
          config.build_settings['OTHER_CFLAGS'] << '-DRCT_NEW_ARCH_ENABLED=1'
        else
          # Use Legacy Architecture
          config.build_settings['RCT_NEW_ARCH_ENABLED'] = '0'
        end

        # Fix modular headers issues
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['DEFINES_MODULE'] = 'YES'

        # Additional fixes for React Native 0.81
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'

        # C++ settings
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
      end
    end

    # RN 0.81 + Fabric: ReactCodegen can end up with several PBXFileReferences whose path is only
    # "Props.cpp" / "EventEmitters.cpp" / … (no directory). Xcode treats them as one file, so
    # rnscreens / RNCWebView / … symbols never link. Remove those ambiguous compile entries and add
    # one explicit file reference per generated cpp (path relative to Pods/).
    fix_react_codegen_third_party_component_sources!(installer) if $RCT_NEW_ARCH_ENABLED
  end
end

def fix_react_codegen_third_party_component_sources!(installer)
  require 'pathname'
  require 'xcodeproj'

  project = installer.pods_project
  target = project.targets.find { |t| t.name == 'ReactCodegen' }
  return unless target

  ios_root = installer.sandbox.root.parent
  codegen_root = File.join(ios_root, 'build', 'generated', 'ios')
  return unless Dir.exist?(codegen_root)

  pods_root = File.join(ios_root, 'Pods')
  phase = target.source_build_phase
  basenames = %w[Props.cpp ComponentDescriptors.cpp EventEmitters.cpp ShadowNodes.cpp States.cpp].freeze

  phase.files.to_a.each do |build_file|
    ref = build_file.file_ref
    next unless ref && ref.path
    next unless basenames.include?(File.basename(ref.path))
    next if ref.path.include?('/')

    phase.files.delete(build_file)
  end

  pattern = File.join(codegen_root, 'react', 'renderer', 'components', '*', '*.cpp')
  Dir.glob(pattern).sort.each do |abs|
    rel_from_pods = Pathname.new(abs).relative_path_from(Pathname.new(pods_root)).to_s
    next if phase.files.any? { |bf| bf.file_ref && bf.file_ref.path == rel_from_pods }

    file_ref = project.files.find { |f| f.path == rel_from_pods }
    file_ref ||= project.new_file(rel_from_pods)
    phase.add_file_reference(file_ref)
  end

  project.save
end
